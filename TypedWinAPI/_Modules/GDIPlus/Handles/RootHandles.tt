<#@ template debug="false" hostspecific="true" language="C#" compilerOptions="/langversion:latest /nullable:enable" #>
<#@ assembly name="System.Core" #>
<#@ import namespace="System.Linq" #>
<#@ import namespace="System.Text" #>
<#@ import namespace="System.Collections.Generic" #>
<#@ output extension=".g.cs" #>
#nullable enable
using System.Diagnostics;
using System.Diagnostics.CodeAnalysis;
using System.Runtime.CompilerServices;
using System.Runtime.InteropServices;
using System.Numerics;

namespace TypedWinAPI.GDIPlus;

<#
	Generate(new Handle(
		"HSessionToken", null,
		["Handle"]));
	Generate(new Handle(
		"HPen", null,
		["Handle"]));
	Generate(new Handle(
		"HPath", null,
		["Handle"]));
	Generate(new Handle(
		"HMatrix", null,
		["Handle"]));
	Generate(new Handle(
		"HGraphics", null,
		["Handle"]));
	Generate(new Handle(
		"HImage", null,
		["Handle"]));
	Generate(new Handle(
		"HStringFormat", null,
		["Handle"]));
	Generate(new Handle(
		"HBrush", null,
		["Handle"]));
	Generate(new Handle(
		"HFontFamily", null,
		["Handle"]));
	Generate(new Handle(
		"HFontCollection", null,
		["Handle"]));
	Generate(new Handle(
		"HFont", null,
		["Handle"]));
#>

#nullable restore
<#@ include file="$(ProjectDir)/Handles/Handle.tt" #>